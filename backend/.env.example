# Example environment for Investe Bem Backend
APP_NAME=Investe Bem Brasil API
APP_VERSION=0.1.0
DEBUG=false
DATABASE_URL=sqlite:///./app/db/investebem.db
DEFAULT_SYMBOLS=PETR4.SA,VALE3.SA,IVVB11.SA,BTC-USD
GEMINI_API_KEY=
GEMINI_MODEL=models/gemini-2.5-pro
ANOMALY_THRESHOLD_PCT=3.0
ATR_BREAKOUT_MULTIPLIER=1.5
VOLUME_SPIKE_MULTIPLIER=2.0
REBALANCE_TOLERANCE=0.2
RISK_FREE_RATE=0.035
SCHEDULER_TICK_SECONDS=300
ALERT_EMAIL_FROM=
ALERT_EMAIL_RECIPIENTS=
